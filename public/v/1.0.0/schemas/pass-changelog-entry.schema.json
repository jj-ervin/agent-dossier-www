{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-dossier.org/v/1.0.0/schemas/pass-changelog-entry.schema.json",
  "title": "PASS Changelog Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pass_id",
    "timestamp",
    "specification_version",
    "change_type",
    "summary",
    "compatibility_impact",
    "affected_sections",
    "authoring_agent"
  ],
  "properties": {
    "pass_id": {
      "type": "string",
      "pattern": "^PASS-[0-9]{4}-[0-9]{4}$"
    },
    "timestamp": { "$ref": "#/$defs/rfc3339_utc" },
    "specification_version": { "$ref": "#/$defs/semver" },
    "change_type": {
      "enum": ["added", "changed", "deprecated", "removed", "fixed", "security"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "compatibility_impact": {
      "enum": ["none", "backward-compatible", "backward-incompatible"]
    },
    "affected_sections": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "authoring_agent": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "audit_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "rfc3339_utc": {
      "type": "string",
      "description": "UTC timestamp at whole-second precision. Fractional seconds are intentionally rejected for deterministic canonical output.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
