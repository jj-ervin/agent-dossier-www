{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-dossier.org/v/1.0.0/schemas/handoff-envelope.schema.json",
  "title": "Agent Handoff Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "envelope_id",
    "from_agent",
    "to_agent",
    "created_at",
    "task_state",
    "completed_work",
    "remaining_work",
    "assumptions",
    "risks",
    "verification"
  ],
  "properties": {
    "type": { "const": "agent_handoff" },
    "envelope_id": {
      "type": "string",
      "pattern": "^agent_handoff:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "from_agent": { "$ref": "#/$defs/agent_id" },
    "to_agent": { "$ref": "#/$defs/agent_id" },
    "created_at": { "$ref": "#/$defs/rfc3339_utc" },
    "task_state": {
      "enum": ["in_progress", "blocked", "ready_for_review", "completed"]
    },
    "completed_work": { "$ref": "#/$defs/string_list" },
    "remaining_work": { "$ref": "#/$defs/string_list" },
    "assumptions": { "$ref": "#/$defs/string_list" },
    "risks": { "$ref": "#/$defs/string_list" },
    "verification": { "$ref": "#/$defs/string_list" },
    "known_failures": { "$ref": "#/$defs/string_list" },
    "reproduction_steps": { "$ref": "#/$defs/string_list" },
    "session_id": {
      "type": "string",
      "description": "Groups sequential handoffs in a multi-turn agent session. All handoffs in the same session SHOULD share the same session_id.",
      "minLength": 1
    },
    "parent_envelope_id": {
      "type": "string",
      "description": "The envelope_id of the immediately preceding handoff in this session. Enables chain reconstruction without storing session state.",
      "pattern": "^agent_handoff:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "version"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "description": "SHA-256 hex digest of the artifact content for integrity verification.",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "unresolved_questions": { "$ref": "#/$defs/string_list" }
  },
  "$defs": {
    "agent_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "rfc3339_utc": {
      "type": "string",
      "description": "UTC timestamp at whole-second precision. Fractional seconds are intentionally rejected for deterministic canonical output.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "string_list": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
